{
    "name": "@ynode/sqrl-lint",
    "version": "1.0.1+96290.97329ed",
    "description": "Squirrelly syntax linter and formatter",
    "type": "module",
    "main": "src/linter.js",
    "types": "index.d.ts",
    "exports": {
        ".": {
            "types": "./index.d.ts",
            "default": "./src/linter.js"
        },
        "./prettier": "./src/prettier-plugin.js"
    },
    "bin": {
        "sqrl-lint": "cli.js"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/yammm/ynode-sqrl-lint.git"
    },
    "keywords": [
        "squirrelly",
        "sqrl",
        "template",
        "linter",
        "formatter",
        "ynode"
    ],
    "scripts": {
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint ./",
        "lint:fix": "eslint ./ --fix",
        "docs": "node scripts/gen-docs.mjs",
        "docs:clean": "rimraf docs || rmdir /s /q docs 2> NUL || true",
        "docs:open": "node -e \"import('node:child_process').then(m=>m.exec(process.platform==='win32'?'start docs/index.html':(process.platform==='darwin'?'open docs/index.html':'xdg-open docs/index.html')))\"",
        "changelog": "auto-changelog -p && git add CHANGELOG.md",
        "ver:preview": "npx autover --no-amend --dry-run --short",
        "ver:apply": "npx autover --guard-unchanged --short",
        "postversion": "git push && git push --tags",
        "test": "node --test"
    },
    "dependencies": {
        "fast-glob": "^3.3.2",
        "yargs": "^18.0.0"
    },
    "author": "Michael Welter <me@mikinho.com>",
    "license": "MIT",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@eslint/json": "^1.0.1",
        "@eslint/markdown": "^7.5.1",
        "@mikinho/autover": "^2.0.1",
        "auto-changelog": "^2.5.0",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "globals": "^17.4.0",
        "jsdoc": "^4.0.5",
        "prettier": "^3.8.1",
        "rimraf": "^6.1.3",
        "wtfnode": "^0.10.1"
    }
}
